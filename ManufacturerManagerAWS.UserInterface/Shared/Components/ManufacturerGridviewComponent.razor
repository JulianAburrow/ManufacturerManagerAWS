<MudTable Items="Manufacturers"
          SortLabel="SortBy"
          Hover
          RowsPerPage="10"
          FixedHeader
          Height="500px">
    <HeaderContent>
        <MudTh title="Sort by Name">
            <MudTableSortLabel SortBy="new Func<ManufacturerWithWidgetCountDto, object>(x => x.Name)">
                Name
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Status">
            <MudTableSortLabel SortBy="new Func<ManufacturerWithWidgetCountDto, object>(x => x.StatusName)">
                Status
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Widget Count">
            <MudTableSortLabel SortBy="new Func<ManufacturerWithWidgetCountDto, object>(x => x.WidgetCount)">
                Widget Count
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.StatusName</MudTd>
        <MudTd>@context.WidgetCount</MudTd>
        <MudTd>
            <a class="btn btn-primary" href=@($"/manufacturer/view/{Uri.EscapeDataString(context.ManufacturerId)}")>View</a>
            &nbsp;
            <a class="btn btn-primary" href=@($"/manufacturer/edit/{Uri.EscapeDataString(context.ManufacturerId)}")>Edit</a>
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50, 100, int.MaxValue }" />
    </PagerContent>
</MudTable>