<br />
<br />

@if (Widgets.Count == 0)
{
    <MudAlert Severity="Severity.Warning" ContentAlignment="HorizontalAlignment.Center">
        <h4>No widgets found.</h4>
    </MudAlert>
    return;
}

<MudTable Items="Widgets"
    SortLabel="SortBy"
    Hover
    RowsPerPage="10"
    FixedHeader
    Height="500px">
    <HeaderContent>
        <MudTh title="Sort by Name">
            <MudTableSortLabel SortBy="new Func<WidgetDetailsDto, object>(x => x.Name)">
                Name
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Manufacturer">
            <MudTableSortLabel SortBy="@((WidgetDetailsDto x) => x.ManufacturerName ?? "Unknown")">
                Manufacturer
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Colour">
            <MudTableSortLabel SortBy="@((WidgetDetailsDto x) => x.ColourName ?? "Unknown")">
                Colour
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Cost Price">
            <MudTableSortLabel SortBy="new Func<WidgetDetailsDto, object>(x => x.CostPrice)">
                Cost Price
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Stock Level">
            <MudTableSortLabel SortBy="new Func<WidgetDetailsDto, object>(x => x.StockLevel)">
                Stock Level
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Net Stock Value">
            <MudTableSortLabel SortBy="@((WidgetDetailsDto x) => x.StockLevel * x.CostPrice)">
                Net Stock Value
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Status">
            <MudTableSortLabel SortBy="@((WidgetDetailsDto x) => x.StatusName ?? "Unknown")">
                Status
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.ManufacturerName</MudTd>
        <MudTd>@(context.ColourName != null ? context.ColourName : "None")</MudTd>
        <MudTd>£@context.CostPrice</MudTd>
        <MudTd>@context.StockLevel</MudTd>
        <MudTd>£@(context.StockLevel* context.CostPrice)</MudTd>
        <MudTd>@context.StatusName</MudTd>
        <MudTd>
            <a href=@($"/widget/view/{Uri.EscapeDataString(context.WidgetId)}") class="btn btn-primary">View</a>
            &nbsp;
            <a href=@($"/widget/edit/{Uri.EscapeDataString(context.WidgetId)}") class="btn btn-primary">Edit</a>
        </MudTd>
    </RowTemplate>
    <FooterContent>
        <MudTd></MudTd>
        <MudTd></MudTd>
        <MudTd></MudTd>
        <MudTd></MudTd>
        <MudTd>Total Stock Value</MudTd>
        <MudTd>£@TotalStockValue</MudTd>
        <MudTd></MudTd>
    </FooterContent>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 15, int.MaxValue }" />
    </PagerContent>
</MudTable>