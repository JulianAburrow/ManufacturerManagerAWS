<MudTable Items="Colours"
          SortLabel="SortBy"
          Hover
          RowsPerPage="10"
          FixedHeader
          Height="500px">
    <HeaderContent>
        <MudTh title="Sort by Name">
            <MudTableSortLabel SortBy="new Func<ColourWithWidgetCountDto, object>(x => x.Name)">
                Name
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Widget Count">
            <MudTableSortLabel SortBy="new Func<ColourWithWidgetCountDto, object>(x => x.WidgetCount)">
                Widget Count
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Name</MudTd>
        <MudTd>@context.WidgetCount</MudTd>
        <MudTd>
            <a class="btn btn-primary" href=@($"/colour/view/{Uri.EscapeDataString(context.ColourId)}")>View</a>
            &nbsp;
            <a class="btn btn-primary" href=@($"/colour/edit/{Uri.EscapeDataString(context.ColourId)}")>Edit</a>
            @if (context.WidgetCount == 0)
            {
                @:&nbsp;
                <a class="btn btn-danger" href=@($"/colour/delete/{Uri.EscapeDataString(context.ColourId)}")>Delete</a>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50, 100, int.MaxValue }" />
    </PagerContent>
</MudTable>