<MudTable Items="ColourJustifications"
          SortLabel="SortBy"
          Hover
          RowsPerPage="10"
          FixedHeader
          Height="500px">
    <HeaderContent>
        <MudTh title="Sort by Name">
            <MudTableSortLabel SortBy="new Func<ColourJustificationWithWidgetCountDto, object>(x => x.Justification)">
                Justification
            </MudTableSortLabel>
        </MudTh>
        <MudTh title="Sort by Widget Count">
            <MudTableSortLabel SortBy="new Func<ColourJustificationWithWidgetCountDto, object>(x => x.WidgetCount)">
                Widget Count
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.Justification</MudTd>
        <MudTd>@context.WidgetCount</MudTd>
        <MudTd>
            <a class="btn btn-primary" href=@($"/colourjustification/view/{Uri.EscapeDataString(context.ColourJustificationId)}")>View</a>
            &nbsp;
            <a class="btn btn-primary" href=@($"/colourjustification/edit/{Uri.EscapeDataString(context.ColourJustificationId)}")>Edit</a>
            @if (context.WidgetCount == 0)
            {
                @:&nbsp;
                <a class="btn btn-danger" href=@($"/colourjustification/delete/{Uri.EscapeDataString(context.ColourJustificationId)}")>Delete</a>
            }
        </MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50, 100, int.MaxValue }" />
    </PagerContent>
</MudTable>